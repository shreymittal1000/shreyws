[Unit]
Description=ShreyWS Borg backup
Documentation=file:/srv/shreyws/infra/docs/backup-restore.md
RequiresMountsFor=/srv/shreyws/backups
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/shreyws-backup
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
