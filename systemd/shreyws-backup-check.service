[Unit]
Description=ShreyWS Borg full repository verification
Documentation=file:/srv/shreyws/infra/docs/backup-restore.md
RequiresMountsFor=/srv/shreyws/backups

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/shreyws-backup-check
Environment=HOME=/var/lib/shreyws-backup/borg-home
Environment=BORG_CACHE_DIR=/var/cache/shreyws-backup/borg-cache
Environment=BORG_CONFIG_DIR=/var/lib/shreyws-backup/borg-config
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
User=root
Group=root
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/srv/shreyws/backups /var/log/shreyws-backup /var/cache/shreyws-backup
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictRealtime=true
RestrictSUIDSGID=true
SystemCallArchitectures=native
