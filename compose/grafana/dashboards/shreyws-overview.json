    {
      "type": "stat",
      "title": "Recent Container Restarts",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 49,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(changes(container_start_time_seconds{name!=\"\"}[30m]))",
