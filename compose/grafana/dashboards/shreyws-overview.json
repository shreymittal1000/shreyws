      },
      "gridPos": {
        "x": 0,
        "y": 53,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[5m]))",
          "legendFormat": "{{name}} rx",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[5m]))",
          "legendFormat": "{{name}} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Container Filesystem Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 53,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
